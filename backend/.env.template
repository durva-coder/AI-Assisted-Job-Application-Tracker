# Production Environment Template
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to Git!
# ============================================

# ==========================================
# Server Configuration
# ==========================================
PORT=5000
NODE_ENV=production

# ==========================================
# MongoDB Configuration
# ==========================================
# MongoDB Atlas (Production):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/job-tracker?retryWrites=true&w=majority
#
# Local Development:
# MONGODB_URI=mongodb://localhost:27017/job-tracker
#
# IMPORTANT:
# - Create free cluster at: https://www.mongodb.com/cloud/atlas
# - URL-encode special characters in password
# - Example encoded: @ becomes %40, # becomes %23
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/job-tracker?retryWrites=true&w=majority

# ==========================================
# JWT Authentication
# ==========================================
# Generate a secure secret:
# - Linux/Mac: openssl rand -base64 64
# - Online: https://generate-secret.vercel.app/64
# - Must be at least 32 characters
# - Use different secrets for dev and production!

JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_MINIMUM_32_CHARACTERS
JWT_EXPIRES_IN=7d

# ==========================================
# OpenAI API (Optional)
# ==========================================
# Get your API key from: https://platform.openai.com/api-keys
# Required for:
# - Job Description Parsing (if not using Gemini)
# - Resume Suggestions (if not using Gemini)
#
# If not provided, AI features will be disabled

OPENAI_API_KEY=sk-your-openai-api-key-here

# ==========================================
# Gemini API (Google AI Studio) - RECOMMENDED
# ==========================================
# Get your API key from: https://aistudio.google.com/app/apikey
# This is used as a drop-in replacement for OpenAI
# Uses the OpenAI-compatible endpoint with Gemini models
#
# Benefits:
# - Free tier: 15 RPM, 1,000,000 TPM per day
# - No credit card required
# - Generous free quota
#
# Models available:
# - gemini-2.0-flash (fast, recommended)
# - gemini-2.0-flash-lite (lighter weight)
# - gemini-1.5-pro (more capable)

GEMINI_API_KEY=your-gemini-api-key-here

# ==========================================
# CORS Configuration
# ==========================================
# Comma-separated list of allowed frontend URLs
# Examples:
#   Single domain: https://your-app.vercel.app
#   Multiple domains: https://your-app.vercel.app,https://your-app.netlify.app
#   With custom domain: https://jobtracker.yourdomain.com
#   Local development: http://localhost:5173,http://localhost:3000
#
# IMPORTANT:
# - No trailing slashes
# - Include protocol (http:// or https://)
# - Be specific (avoid * in production)

FRONTEND_URL=http://localhost:5173

# ==========================================
# Logging (Optional )
# ==========================================
# Uncomment to enable detailed logging
# LOG_LEVEL=info
# LOG_FORMAT=combined

# ==========================================
# Rate Limiting ( Optional)
# ==========================================
# Uncomment to enable rate limiting
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# Deployment Checklist
# ==========================================
# Before deploying to production:
# 
# [ ] MongoDB Atlas cluster created
# [ ] Database user created with read/write permissions
# [ ] Network access configured (IP whitelist)
# [ ] JWT_SECRET is a strong random string (64+ chars)
# [ ] OPENAI_API_KEY is set (if using AI features)
# [ ] FRONTEND_URL matches your deployed frontend
# [ ] NODE_ENV is set to "production"
# [ ] .env file is in .gitignore
# [ ] HTTPS is enabled on all domains
#
# ==========================================
# Security Notes
# ==========================================
# 1. Never commit .env files to version control
# 2. Use different values for development and production
# 3. Rotate JWT_SECRET periodically
# 4. Monitor MongoDB storage usage
# 5. Enable MongoDB Atlas backup
# 6. Use environment variables from your hosting platform
#    (Render, Railway, etc.) instead of .env files in production
